#!/usr/bin/env bash
set -euo pipefail

# gmail-await: Poll Gmail inbox until a new email arrives, then describe it.

usage() {
  cat <<'EOF'
Usage: gmail-await [flags]

Poll Gmail inbox until new emails arrive, then print one JSON line per
email and exit.

Flags:
  --start-history-id <id>  Resume from this history ID instead of snapshotting
  --timeout <seconds>      Maximum time to wait in seconds (exit 1 if exceeded)
  --help                   Show this help message

Exit codes:
  0   New email(s) detected, descriptions printed to stdout
  1   Timeout exceeded, or runtime error
  2   Bad arguments or usage error

Environment variables:
  GMAIL_AWAIT_POLL_INTERVAL  Poll interval in seconds (default: 60)
EOF
}

die() {
  echo "Error: $1" >&2
  exit "${2:-1}"
}

# --- Phase 1: Parse arguments ---

timeout=""
start_history_id=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --start-history-id)
      [[ -n "${2:-}" ]] || die "--start-history-id requires a value" 2
      start_history_id="$2"
      shift 2
      ;;
    --timeout)
      [[ -n "${2:-}" ]] || die "--timeout requires a value" 2
      timeout="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    -*)
      die "Unknown flag: $1" 2
      ;;
    *)
      die "Unexpected argument: $1" 2
      ;;
  esac
done

if [[ -n "$timeout" ]]; then
  if ! [[ "$timeout" =~ ^[0-9]+$ ]] || [[ "$timeout" -lt 1 ]]; then
    die "--timeout must be a positive number" 2
  fi
fi

# --- Phase 2: Snapshot current state ---

snapshot_from_profile() {
  local profile_json
  profile_json=$(gws gmail users getProfile --params '{"userId": "me"}' 2>/dev/null) || die "Could not fetch Gmail profile. Check gws authentication." 1
  history_id=$(echo "$profile_json" | jq -r '.historyId')
  [[ -n "$history_id" && "$history_id" != "null" ]] || die "Could not extract historyId from profile" 1
}

if [[ -n "$start_history_id" ]]; then
  history_id="$start_history_id"
  echo "Resuming from history ID ${history_id}..." >&2
else
  snapshot_from_profile
fi

echo "Watching Gmail inbox for new emails..." >&2

# --- Phase 3: Poll loop ---

poll_interval="${GMAIL_AWAIT_POLL_INTERVAL:-60}"
start_time=$(date +%s)

while true; do
  # Check timeout and compute sleep duration
  if [[ -n "$timeout" ]]; then
    elapsed=$(( $(date +%s) - start_time ))
    remaining=$(( timeout - elapsed ))
    if [[ "$remaining" -le 0 ]]; then
      echo "Timeout after ${timeout}s with no new emails." >&2
      exit 1
    fi
    if [[ "$remaining" -lt "$poll_interval" ]]; then
      sleep "$remaining"
      echo "Timeout after ${timeout}s with no new emails." >&2
      exit 1
    fi
  fi

  sleep "$poll_interval"

  # Check for new messages since our snapshot
  if ! history_json=$(gws gmail users history list --page-all --params "{\"userId\": \"me\", \"startHistoryId\": \"${history_id}\", \"historyTypes\": \"messageAdded\", \"labelId\": \"INBOX\"}" 2>/dev/null); then
    # Handle expired/invalid history ID by falling back to getProfile
    if [[ -n "$start_history_id" ]]; then
      echo "Warning: history ID may be expired, re-snapshotting from profile..." >&2
      snapshot_from_profile
      start_history_id=""
    else
      echo "Warning: API error, retrying next cycle..." >&2
    fi
    continue
  fi

  # Extract all unique message IDs from new messages across all pages
  mapfile -t message_ids < <(echo "$history_json" | jq -r '.history[]?.messagesAdded[]?.message.id // empty' | sort -u)

  if [[ ${#message_ids[@]} -eq 0 ]]; then
    continue
  fi

  # Extract the history ID from the response (checkpoint for next invocation)
  response_history_id=$(echo "$history_json" | jq -r '.historyId // empty' | tail -1)

  # Fetch and output each message as a JSON line
  for msg_id in "${message_ids[@]}"; do
    message_json=$(gws gmail users messages get --params "{\"userId\": \"me\", \"id\": \"${msg_id}\", \"format\": \"full\"}" 2>/dev/null) || {
      echo "Warning: Could not fetch message ${msg_id}, skipping..." >&2
      continue
    }

    echo "$message_json" | jq -c '{
      from: ([.payload.headers[] | select(.name == "From") | .value] | .[0] // ""),
      to: ([.payload.headers[] | select(.name == "To") | .value] | .[0] // ""),
      subject: ([.payload.headers[] | select(.name == "Subject") | .value] | .[0] // ""),
      date: ([.payload.headers[] | select(.name == "Date") | .value] | .[0] // ""),
      snippet: (.snippet // ""),
      labels: (.labelIds // [] | join(", ")),
      messageId: (.id // ""),
      threadId: (.threadId // "")
    }'
  done

  # Print the historyId checkpoint as the final line
  jq -nc --arg hid "$response_history_id" '{historyId: $hid}'

  exit 0
done
